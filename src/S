function TransitionTable({ dfa, title, highlightedStates = [], activeSymbol = null }: { dfa: DFA | MinimizedDFA | StepGraph; title?: string; highlightedStates?: string[]; activeSymbol?: string | null; }) {
  return (
    <Card className="h-full flex flex-col">
      {title ? <CardHeader><CardTitle>{title}</CardTitle></CardHeader> : null}
      <CardContent className="flex-1 overflow-auto pt-6">
        <div className="rounded-xl border border-slate-800 bg-[#0f172a] overflow-hidden">
          <table className="w-full text-sm">
            <thead className="bg-[#1e293b] text-slate-200 sticky top-0 z-10">
              <tr>
                <th className="px-4 py-3 text-left font-semibold border-b border-slate-700">State</th>
                {dfa.alphabet.map((symbol) => (
                  <th key={symbol} className={`px-4 py-3 text-left font-semibold border-b border-slate-700 transition-colors ${activeSymbol === symbol ? "bg-violet-900/60 text-violet-200" : ""}`}>
                    Input {symbol}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {dfa.states.map((state) => {
                const isHighlighted = highlightedStates.some(h => state === h || state.includes(h));
                return (
                  <tr key={state} className={`border-b border-slate-800/60 last:border-0 transition-colors ${isHighlighted ? "bg-emerald-900/20" : ""}`}>
                    <td className={`px-4 py-3 font-medium ${isHighlighted ? "text-emerald-300 font-bold" : "text-slate-300"}`}>
                      {state}
                      {dfa.startState === state && <Badge variant="outline" className="ml-2 text-[10px] scale-90 text-slate-400 border-slate-700">Start</Badge>}
                      {dfa.finalStates.includes(state) && <Badge variant="outline" className="ml-2 text-[10px] scale-90 border-emerald-500/50 text-emerald-400">Final</Badge>}
                    </td>
                    {dfa.alphabet.map((symbol) => {
                      const activeCell = isHighlighted && activeSymbol === symbol;
                      const activeColumn = activeSymbol === symbol;
                      return (
                        <td key={`${state}-${symbol}`} className={`px-4 py-3 transition-colors ${activeCell ? "bg-violet-600/40 font-bold text-violet-200 border border-violet-500/50" : activeColumn ? "bg-violet-900/20 text-slate-300" : "text-slate-400"}`}>
                          {dfa.transitions[state][symbol]}
                        </td>
                      );
                    })}
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </CardContent>
    </Card>
  );
}

function PairTableSnapshot({ rows, activePair }: { rows: PairTableEntry[]; activePair: [string, string] }) {
  return (
    <Card className="h-full flex flex-col">
      <CardHeader>
        <CardTitle className="flex items-center gap-2">
          <CheckSquare className="h-5 w-5 text-violet-500" /> Myhill-Nerode Markings
        </CardTitle>
      </CardHeader>
      <CardContent className="flex-1 overflow-y-auto max-h-[350px] pt-6">
        <div className="rounded-xl border border-slate-800 overflow-hidden">
          <table className="w-full text-sm">
            <thead className="bg-[#1e293b] text-slate-200 sticky top-0 z-10">
              <tr>
                <th className="px-4 py-3 text-left font-semibold border-b border-slate-700">Pair</th>
                <th className="px-4 py-3 text-left font-semibold border-b border-slate-700">Status</th>
              </tr>
            </thead>
            <tbody>
              {rows.map((row) => {
                const isActive = row.pair[0] === activePair[0] && row.pair[1] === activePair[1];
                return (
                  <tr key={`${row.pair[0]}-${row.pair[1]}`} className={`border-b border-slate-800/60 last:border-0 transition-colors ${isActive ? "bg-violet-900/30" : "bg-[#0f172a]"}`}>
                    <td className={`px-4 py-2 font-medium ${isActive ? "text-violet-300 font-bold" : "text-slate-300"}`}>({row.pair[0]}, {row.pair[1]})</td>
                    <td className="px-4 py-2">
                      <Badge variant={row.mark === "marked" ? "destructive" : "success"}>
                        {row.mark === "marked" ? "Marked (≠)" : "Unmarked (≡)"}
                      </Badge>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </CardContent>
    </Card>
  );
}

function GraphView({ dfa, title, graphKey, activeStates = [], mergeMode = false }: { dfa: DFA | MinimizedDFA | StepGraph; title: string; graphKey: string; activeStates?: string[]; mergeMode?: boolean; }) {
  const nodes = dfa.states;
  const centerX = 250;
  const centerY = 180;
  const radius = Math.max(90, 140 - nodes.length * 4);

  const positions = nodes.reduce<Record<string, { x: number; y: number }>>((acc, state, idx) => {
    const angle = (2 * Math.PI * idx) / Math.max(nodes.length, 1) - Math.PI / 2;
    acc[state] = {
      x: centerX + radius * Math.cos(angle),
      y: centerY + radius * Math.sin(angle)
    };
    return acc;
  }, {});

  return (
    <Card className="overflow-hidden h-full flex flex-col">
      <CardHeader>
        <CardTitle>{title}</CardTitle>
      </CardHeader>
      <CardContent className="flex-1 p-0 flex items-center justify-center relative min-h-[350px]">
        <AnimatePresence mode="wait">
          <motion.svg
            key={graphKey}
            initial={{ opacity: 0, scale: 0.96 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 1.02 }}
            transition={{ duration: 0.4 }}
            viewBox="0 0 500 360"
            className="absolute inset-0 w-full h-full bg-[#020617] rounded-b-xl"
          >
            <defs>
              <marker id={`arrow-${graphKey}`} viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                <path d="M 0 0 L 10 5 L 0 10 z" className="fill-slate-500" />
              </marker>
              {/* Glow filter for active nodes */}
              <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur stdDeviation="6" result="blur" />
                <feComposite in="SourceGraphic" in2="blur" operator="over" />
              </filter>
            </defs>

            {dfa.states.flatMap((from) =>
              dfa.alphabet.map((symbol, index) => {
                const to = dfa.transitions[from][symbol];
                const p1 = positions[from];
                const p2 = positions[to];
                const selfLoop = from === to;

                if (selfLoop) {
                  return (
                    <motion.g key={`${from}-${symbol}`} initial={{ opacity: 0 }} animate={{ opacity: 1 }} transition={{ duration: 0.35 }}>
                      <path d={`M ${p1.x} ${p1.y - 25} C ${p1.x - 45} ${p1.y - 80}, ${p1.x + 45} ${p1.y - 80}, ${p1.x} ${p1.y - 25}`} fill="none" strokeWidth="2" markerEnd={`url(#arrow-${graphKey})`} className="stroke-slate-600" />
                      <rect x={p1.x - 10} y={p1.y - 90 - index * 12} width="20" height="14" rx="4" className="fill-[#1e293b]" />
                      <text x={p1.x} y={p1.y - 80 - index * 12} textAnchor="middle" className="fill-slate-300 text-[11px] font-semibold">{symbol}</text>
                    </motion.g>
                  );
                }

                const dx = p2.x - p1.x;
                const dy = p2.y - p1.y;
                const dist = Math.sqrt(dx * dx + dy * dy) || 1;
                const ux = dx / dist;
                const uy = dy / dist;
                const startX = p1.x + ux * 25;
                const startY = p1.y + uy * 25;
                const endX = p2.x - ux * 25;
                const endY = p2.y - uy * 25;
                const midX = (startX + endX) / 2 + (index === 0 ? -12 : 12);
                const midY = (startY + endY) / 2 + (index === 0 ? 12 : -12);

                return (
                  <motion.g key={`${from}-${symbol}`} initial={{ opacity: 0 }} animate={{ opacity: 1 }} transition={{ duration: 0.35 }}>
                    <line x1={startX} y1={startY} x2={endX} y2={endY} strokeWidth="2" markerEnd={`url(#arrow-${graphKey})`} className="stroke-slate-600" />
                    <rect x={midX - 10} y={midY - 10} width="20" height="16" rx="4" className="fill-[#1e293b] border border-slate-700" />
                    <text x={midX} y={midY + 1} textAnchor="middle" className="fill-violet-300 text-[11px] font-bold">{symbol}</text>
                  </motion.g>
                );
              })
            )}

            <line x1={positions[dfa.startState]?.x ? positions[dfa.startState].x - 60 : 20} y1={positions[dfa.startState]?.y ?? 180} x2={positions[dfa.startState]?.x ? positions[dfa.startState].x - 30 : 60} y2={positions[dfa.startState]?.y ?? 180} strokeWidth="2.5" markerEnd={`url(#arrow-${graphKey})`} className="stroke-emerald-500" />

            {dfa.states.map((state) => {
              const position = positions[state];
              const isFinal = dfa.finalStates.includes(state);
              const isActive = activeStates.some(a => state === a || state.includes(a));
              return (
                <motion.g key={state} initial={{ opacity: 0, scale: 0.5 }} animate={{ opacity: 1, scale: isActive && mergeMode ? 1.15 : isActive ? 1.08 : 1 }} transition={{ type: "spring", stiffness: 300, damping: 20 }}>
                  <circle cx={position.x} cy={position.y} r="25" className={`fill-[#0f172a] ${isActive ? "stroke-violet-500 stroke-[3px]" : "stroke-slate-600"} `} strokeWidth="2" filter={isActive ? "url(#glow)" : ""} />
                  {isFinal && <circle cx={position.x} cy={position.y} r="20" className="fill-none stroke-emerald-500" strokeWidth="2" />}
                  <text x={position.x} y={position.y + 4} textAnchor="middle" className="fill-white text-[11px] font-bold">{state}</text>
                </motion.g>
              );
            })}
          </motion.svg>
        </AnimatePresence>
      </CardContent>
    </Card>
  );
}

function PartitionTable({ partitions }: { partitions: string[][] }) {
  return (
    <Card className="h-full flex flex-col">
      <CardHeader>
        <CardTitle>Current Partitions</CardTitle>
      </CardHeader>
      <CardContent className="flex-1 overflow-auto pt-6">
        <div className="grid gap-3 sm:grid-cols-2">
          {partitions.map((group, idx) => (
            <motion.div key={idx} layout initial={{ opacity: 0, scale: 0.97 }} animate={{ opacity: 1, scale: 1 }} className="rounded-2xl border border-[#334155] bg-[#1e293b]/50 p-4 shadow-sm">
              <div className="mb-3 flex items-center justify-between">
                <div className="text-sm font-semibold text-slate-300">Group {idx + 1}</div>
                <Badge variant="secondary">{group.length}</Badge>
