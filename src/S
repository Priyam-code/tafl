                  </div>
                  <div>
                    <label className="mb-2 block text-sm font-semibold text-slate-300">Final States (comma separated)</label>
                    <Input value={formState.finalStatesText} onChange={(e) => setFormState(p => ({ ...p, finalStatesText: e.target.value }))} className="rounded-xl" />
                  </div>
                </div>

                <div>
                  <label className="mb-3 block text-sm font-semibold text-slate-300">Transition Table</label>
                  <div className="overflow-x-auto rounded-2xl border border-slate-800 bg-[#0f172a]">
                    <table className="w-full text-sm">
                      <thead className="bg-[#1e293b] text-slate-200">
                        <tr>
                          <th className="px-4 py-3 text-left font-semibold border-b border-slate-700">Current State</th>
                          {formAlphabet.map((symbol) => (
                            <th key={symbol} className="px-4 py-3 text-left font-semibold border-b border-slate-700">Next on {symbol}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {formStates.map((state) => (
                          <tr key={state} className="border-b border-slate-800/60 last:border-0">
                            <td className="px-4 py-4 font-medium text-white">{state}</td>
                            {formAlphabet.map((symbol) => (
                              <td key={`${state}-${symbol}`} className="px-4 py-4">
                                <Input
                                  value={formState.transitions[state]?.[symbol] ?? ""}
                                  onChange={(e) => setFormState(p => ({ ...p, transitions: { ...p.transitions, [state]: { ...p.transitions[state], [symbol]: e.target.value } } }))}
                                  className="min-w-[110px] rounded-xl bg-[#1e293b]"
                                />
                              </td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>

                <div className="flex flex-wrap gap-4 pt-2">
                  <Button className="rounded-xl px-6" onClick={buildAndRunFromTable}><Play className="mr-2 h-4 w-4" /> Start Visualizer</Button>
                  <Button variant="secondary" className="rounded-xl px-6" onClick={loadSample}><RotateCcw className="mr-2 h-4 w-4" /> Load Sample</Button>
                </div>
                
                {formError && (
                  <div className="flex items-start gap-3 rounded-2xl border border-rose-500/30 bg-rose-500/10 p-5 text-rose-300 mt-4"><AlertCircle className="mt-0.5 h-5 w-5 text-rose-400" /><div><div className="font-semibold text-white mb-1">Form Error</div><div className="text-sm">{formError}</div></div></div>
                )}
              </div>
            ) : (
              <div className="space-y-6">
                <Textarea value={input} onChange={(e) => setInput(e.target.value)} className="min-h-[420px] rounded-2xl font-mono text-sm bg-[#1e293b]" />
                <div className="flex flex-wrap gap-4 pt-2">
                  <Button className="rounded-xl px-6" onClick={() => startWalkthrough(input)}><Play className="mr-2 h-4 w-4" /> Start Visualizer</Button>
                  <Button variant="secondary" className="rounded-xl px-6" onClick={loadSample}><RotateCcw className="mr-2 h-4 w-4" /> Load Sample</Button>
                </div>
              </div>
            )}
          </CardContent>
        </Card>
      </div>
    </div>
  );
}